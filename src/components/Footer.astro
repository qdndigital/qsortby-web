---
import { SUPPORT_EMAIL, DEMO_URL } from '../consts';
const year = 2026;
---
<footer class="site">
  <div class="wrap">
    <div class="foot">
      <div>
        <a href="/" class="logo" aria-label="QSortby home">
          <svg class="logomark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect x="2.5" y="2.5" width="27" height="27" rx="7" stroke="#191a12" stroke-width="2"/>
            <rect x="13.25" y="7.6" width="5.5" height="5.5" rx="1.5" fill="#0e9d63"/>
            <rect x="13.25" y="13.75" width="5.5" height="5.5" rx="1.5" fill="#0e9d63" fill-opacity="0.55"/>
            <rect x="13.25" y="19.9" width="5.5" height="5.5" rx="1.5" fill="#0e9d63" fill-opacity="0.28"/>
          </svg>
          <span>QSortby</span>
        </a>
        <p class="fd">Smart collection sorting for Shopify. QSortby turns live store signals into a storefront that merchandises itself — so the right products always lead.</p>
      </div>
      <div>
        <h2>Product</h2>
        <a href="/use-cases">Use cases</a>
        <a href="/integrations">Integrations</a>
        <a href="/pricing">Pricing</a>
      </div>
      <div>
        <h2>Company</h2>
        <a href="/support">Support</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href={`mailto:${SUPPORT_EMAIL}`}>Contact</a>
      </div>
      <div>
        <h2>Get started</h2>
        <a href={DEMO_URL}>Book a demo</a>
        <a href="/pricing">Pricing</a>
        <a href="/use-cases">Use cases</a>
      </div>
    </div>
    <div class="fbar">
      <span>© {year} QSortby. All rights reserved.</span>
      <span>Built for Shopify merchants.</span>
    </div>
  </div>
</footer>
