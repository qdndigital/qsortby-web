---
import Base from '../layouts/Base.astro';
import { SUPPORT_EMAIL, DEMO_URL } from '../consts';

const title = 'Support — QSortby for Shopify';
const description =
  'Get help with QSortby. Email support, response within one business day, and a contact form for setup questions, billing, and data requests.';
const topics = ['General question', 'Demo request', 'Setup & onboarding', 'Billing', 'Bug report', 'Data / privacy request', 'Other'];
---
<Base title={title} description={description}>
  <section class="phero">
    <div class="wrap">
      <div class="crumb"><a href="/">~</a> / support</div>
      <h1>We're here to help.</h1>
      <p>Setup questions, billing, bug reports, or a data request — send a note and we'll get back to you within one business day.</p>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="contact-grid">
        <div class="cinfo rv">
          <div class="r"><div class="k">Email</div><div class="v"><a href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a></div></div>
          <div class="r"><div class="k">See it live</div><div class="v"><a href={DEMO_URL} style="color:var(--green-ink)">Book a 15-min demo →</a></div></div>
          <div class="r"><div class="k">Response time</div><div class="v">Within 1 business day</div></div>
          <div class="r"><div class="k">Setup help</div><div class="v">Free for every plan</div></div>
          <div class="r"><div class="k">Data &amp; privacy</div><div class="v font-mono text-sm">Deletion / export requests honored — see <a href="/privacy" class="underline" style="color:var(--green-ink)">Privacy</a></div></div>
        </div>

        <!-- Netlify form: data-netlify enables capture; honeypot blocks bots;
             AJAX submit lives in app.js, native POST to /thank-you is the no-JS fallback. -->
        <form id="brief-form" name="support" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you" class="cform rv"
              data-msg-sending="Sending…" data-msg-ok="Thanks — your message is in. We'll reply within one business day." data-msg-err="Could not send right now — please email us directly.">
          <input type="hidden" name="form-name" value="support" />
          <p class="hidden"><label>Leave this empty: <input name="bot-field" /></label></p>
          <div class="fr"><label for="f-name">Your name</label><input id="f-name" type="text" name="name" placeholder="Jane Merchant" required /></div>
          <div class="fr"><label for="f-email">Email</label><input id="f-email" type="email" name="email" placeholder="you@store.com" required /></div>
          <div class="fr"><label for="f-store">Store URL</label><input id="f-store" type="text" name="store" placeholder="your-store.myshopify.com" /></div>
          <div class="fr"><label for="f-topic">Topic</label><select id="f-topic" name="topic">{topics.map((o) => <option>{o}</option>)}</select></div>
          <div class="fr"><label for="f-msg">Message</label><textarea id="f-msg" name="message" placeholder="How can we help?" required></textarea></div>
          <button type="submit" class="btn btn-accent w-full">Send message <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
          <p class="note">By sending, you agree to our Privacy Policy. We only use your details to respond.</p>
        </form>
      </div>
    </div>
  </section>
</Base>
