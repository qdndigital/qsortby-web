---
import Base from '../layouts/Base.astro';
import { APP_STORE_URL, DEMO_URL } from '../consts';

const title = 'Pricing — QSortby for Shopify';
const description = 'Simple pricing with a 7-day free trial, billed through Shopify. Plans and prices shown are placeholders pending launch.';

const check = '<svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>';
const starter = ['Smart auto-sort by any signal', 'Real-time re-sorting', 'Sold-out auto-demotion', 'Manual order & preview', 'Embedded Shopify dashboard', 'Email support'];
const pro = ['Everything in Starter', 'Per-segment rules', 'Shopper insights & heatmaps', 'Emotional AI intent signals', 'Priority refresh & throughput', 'Priority support'];
---
<Base title={title} description={description}>
  <section class="phero">
    <div class="wrap">
      <div class="crumb"><a href="/">~</a> / pricing</div>
      <h1>Simple pricing. Free for 7 days.</h1>
      <p>Every plan starts with a 7-day free trial and is billed directly through Shopify, on your normal invoice. <strong style="color:var(--green-ink)">Plans and prices below are placeholders</strong> while we finalize launch pricing.</p>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div class="plans">
        <div class="plan rv">
          <span class="ptag">Starter</span>
          <div class="price"><b>$29</b><span>/ month</span></div>
          <p class="pdesc">For solo &amp; small stores that want a storefront that sorts itself.</p>
          <ul>
            {starter.map((f) => <li><span set:html={check} /> {f}</li>)}
          </ul>
          <a href={APP_STORE_URL} class="btn btn-line w-full">Start free trial</a>
        </div>

        <div class="plan feat rv">
          <span class="badge">Most popular</span>
          <span class="ptag">Pro</span>
          <div class="price"><b>$99</b><span>/ month</span></div>
          <p class="pdesc">For growing brands &amp; teams that need segments, insights and control.</p>
          <ul>
            {pro.map((f) => <li><span set:html={check} /> {f}</li>)}
          </ul>
          <a href={DEMO_URL} class="btn btn-accent w-full">Book a demo</a>
        </div>
      </div>

      <p class="kicker" style="text-align:center;margin-top:2rem">Placeholder pricing · billed via Shopify · cancel anytime</p>
    </div>
  </section>

  <!-- comparison matrix -->
  <section class="sec" style="padding-top:0">
    <div class="narrow">
      <div class="shead ctr rv" style="margin-bottom:2rem">
        <span class="eyebrow" style="justify-content:center"><span class="dot"></span> Compare</span>
        <h2>What's in each plan</h2>
      </div>
      <div class="rv" style="overflow-x:auto">
        <table class="matrix">
          <thead>
            <tr><th>Feature</th><th>Starter</th><th class="colhi">Pro</th></tr>
          </thead>
          <tbody>
            <tr><th>Smart auto-sort by any signal</th><td class="yes">✓</td><td class="yes colhi">✓</td></tr>
            <tr><th>Real-time re-sorting</th><td class="yes">✓</td><td class="yes colhi">✓</td></tr>
            <tr><th>Sold-out auto-demotion</th><td class="yes">✓</td><td class="yes colhi">✓</td></tr>
            <tr><th>Manual order & preview</th><td class="yes">✓</td><td class="yes colhi">✓</td></tr>
            <tr><th>Embedded Shopify dashboard</th><td class="yes">✓</td><td class="yes colhi">✓</td></tr>
            <tr><th>Per-segment rules</th><td class="no">—</td><td class="yes colhi">✓</td></tr>
            <tr><th>Shopper insights & heatmaps</th><td class="no">—</td><td class="yes colhi">✓</td></tr>
            <tr><th>Emotional AI intent signals</th><td class="no">—</td><td class="yes colhi">✓</td></tr>
            <tr><th>Refresh & throughput</th><td>Standard</td><td class="colhi">Priority</td></tr>
            <tr><th>Support</th><td>Email</td><td class="colhi">Priority</td></tr>
            <tr><th>Free trial</th><td class="yes">7 days</td><td class="yes colhi">7 days</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="sec" style="padding-top:0">
    <div class="narrow">
      <div class="shead ctr rv" style="margin-bottom:2.5rem">
        <span class="eyebrow" style="justify-content:center"><span class="dot"></span> Billing</span>
        <h2>How billing works</h2>
      </div>
      <div class="faq rv">
        <details><summary>How am I charged?<span class="pm"></span></summary><div class="ans">Through Shopify's Billing API. The subscription appears on your regular Shopify bill — there's no separate payment method to set up and no off-platform charging.</div></details>
        <details><summary>What happens after the trial?<span class="pm"></span></summary><div class="ans">After 7 days, your chosen plan begins. Cancel any time before then at no charge, directly from the app.</div></details>
        <details><summary>Can I switch plans?<span class="pm"></span></summary><div class="ans">Yes — move between plans at any time. Changes take effect on your next billing cycle.</div></details>
        <details><summary>What if I uninstall?<span class="pm"></span></summary><div class="ans">Billing stops on uninstall. Any collections QSortby created stay in your store; it simply stops updating them.</div></details>
      </div>
    </div>
  </section>
</Base>
